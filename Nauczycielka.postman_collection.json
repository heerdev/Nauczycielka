        },
        {
          "name": "Add Transcript",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"content\": \"Variables are containers for storing data values. A variable is created the moment you first assign a value to it. Variables do not need to be declared with any particular type. Every variable in Python is an object.\",\n  \"speaker\": \"Dr. John Smith\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/courses/1/sessions/1/transcripts",
              "protocol": "http",
              "host": ["localhost"],
              "port": "8080",
              "path": ["api", "v1", "courses", "1", "sessions", "1", "transcripts"]
            }
          }
        },
        {
          "name": "End Session & Generate Content",
          "request": {
            "method": "POST",
            "url": {
              "raw": "http://localhost:8080/api/v1/courses/1/sessions/1/end",
