            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Session 1: Variables\",\n  \"description\": \"Learn about variables in Python\"\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/courses/1/sessions",
