              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"title\": \"Advanced Python\",\n  \"description\": \"Learn advanced Python concepts\",\n  \"instructor_id\": 1\n}"
            },
            "url": {
              "raw": "http://localhost:8080/api/v1/courses",
